# SPA routing: any path that isn't a real file/folder falls through to
# index.html so React Router can handle it client-side (Firebase Hosting did
# this via a rewrite rule; Apache needs it spelled out explicitly).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule . /index.html [L]
</IfModule>

# Cache headers, matching the Firebase Hosting config: index.html always
# revalidates (so a redeploy shows up on next refresh, no stale page), while
# content-hashed assets are cached hard since a new build always gets new
# filenames.
<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, max-age=0"
  </FilesMatch>
  <FilesMatch "\.(js|css|png|jpg|jpeg|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Vite's hashed asset filenames never collide across builds, so no explicit
# ETag/If-Modified-Since handling is needed beyond the headers above.
