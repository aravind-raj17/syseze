# Copy this file to .env and fill in real values. Never commit .env.

# Path to the Firebase service account JSON key. Relative paths resolve
# from this folder; absolute paths (starting with /) are used as-is.
SERVICE_ACCOUNT_PATH=service-account.json

# Hostinger email account (Emails -> create a mailbox, e.g. reports@syseze.com)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=reports@syseze.com
SMTP_PASS=
SMTP_FROM_EMAIL=reports@syseze.com
SMTP_FROM_NAME=Syseze IT Operations
