# Defense in depth: this script holds a Firestore service-account key and
# SMTP credentials. It should live OUTSIDE any web-accessible directory and
# only ever be invoked by cron (CLI), never HTTP — but if it's ever placed
# somewhere Apache serves, this blocks every request to the whole folder.
<IfModule mod_authz_core.c>
  Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
  Order deny,allow
  Deny from all
</IfModule>
